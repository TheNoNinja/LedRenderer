{
  "name": "imgui",
  "version": "1.92.7-docking",
  "description": "Dear ImGui: Bloat-free Graphical User interface for C++ with minimal dependencies",
  "platforms": "native",
  "build": {
    "srcDir": "imgui",
    "includeDir": ".",
    "srcFilter": [
      "-<*>",
      "-<backends/>",
      "-<misc/>",
      "-<examples/>",
      "-<docs/>",
      "+<imgui.cpp>",
      "+<imgui_demo.cpp>",
      "+<imgui_draw.cpp>",
      "+<imgui_tables.cpp>",
      "+<imgui_widgets.cpp>",
      "+<backends/imgui_impl_sdl3.cpp>",
      "+<backends/imgui_impl_opengl3.cpp>"
    ]
  }
}
